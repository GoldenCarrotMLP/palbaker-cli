{
  "productName": "PalBaker",
  "version": "0.1.29",
  "identifier": "com.palbaker.app",
  "build": {
    "beforeDevCommand": "pnpm dlx cross-env TAURI_ENV_DEBUG=true TAURI_MODE=true pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/GoldenCarrotMLP/PalBaker/refs/heads/main/palbaker-ui/src-tauri/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxMzQwNzJGNERFNUUyNzMKUldSejR1Vk5Md2MwTWRXQm54TmYzcUQyTC9DRlJsbGRONU5mY2FnRWhVT0o0dGpxeXBkQ3B0KzAK"
    }
  },
  "app": {
    "windows": [
      {
        "title": "PalBaker",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; media-src 'self' asset: http://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "resources/backend/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
